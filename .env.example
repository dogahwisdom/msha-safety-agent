# Environment variables (copy to .env and fill in — never commit .env)

# --- Provider selection ---
# auto (default): OpenAI > Groq > Ollama > offline tools
# LLM_PROVIDER=offline   # deterministic routing ceiling (ablation, no LLM)
# LLM_PROVIDER=groq
# LLM_PROVIDER=ollama
# LLM_PROVIDER=openai

# --- Option A: Groq (FREE — recommended, no credit card) ---
# Sign up: https://console.groq.com
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_BASE_URL=https://api.groq.com/openai/v1

# --- Option B: OpenAI (paid) ---
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# --- Option C: Ollama (local, free) ---
# OLLAMA_MODEL=qwen2.5:7b
# OLLAMA_BASE_URL=http://localhost:11434/v1

# Optional paths
# MSHA_RAW_DIR=data/raw
# MSHA_PROCESSED_DIR=data/processed
