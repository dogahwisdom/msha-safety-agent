# Environment variables (copy to .env and fill in — never commit .env)

# --- Option A: OpenAI (cloud) ---
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# --- Option B: Ollama (local, no key required) ---
# LLM_PROVIDER=ollama
# OLLAMA_MODEL=qwen2.5:7b
# OLLAMA_BASE_URL=http://localhost:11434/v1

# Auto (default): uses OpenAI if OPENAI_API_KEY is set, else Ollama if running locally.
# LLM_PROVIDER=auto

# Optional paths
# MSHA_RAW_DIR=data/raw
# MSHA_PROCESSED_DIR=data/processed
